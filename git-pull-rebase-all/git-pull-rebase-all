#!/bin/zsh
# Script to traverse all folders and run git pull --rebase on git repositories

usage() {
    echo "Usage: git-pull-rebase-all [directory]"
    echo ""
    echo "Traverses all folders in the specified directory (or current directory)"
    echo "and runs 'git pull --rebase' on each git repository found."
    echo ""
    echo "Arguments:"
    echo "  directory    Optional: Directory to scan (defaults to current directory)"
    exit 1
}

# Get the target directory
TARGET_DIR="${1:-.}"

# Check if directory exists
if [ ! -d "$TARGET_DIR" ]; then
    echo "Error: Directory '$TARGET_DIR' does not exist"
    exit 1
fi

echo "Scanning for git repositories in: $TARGET_DIR"
echo "================================================"
echo ""

# Counter for stats
total_repos=0
success_repos=0
failed_repos=0

# Traverse all subdirectories in the target directory
for dir in "$TARGET_DIR"/*/; do
    # Remove trailing slash
    dir="${dir%/}"
    
    # Get just the folder name
    folder_name=$(basename "$dir")
    
    # Check if it's a git repository
    if [ -d "$dir/.git" ]; then
        total_repos=$((total_repos + 1))
        echo "[$folder_name]"
        
        # Change to the directory and run git pull --rebase
        cd "$dir" || {
            echo "  ✗ Failed to enter directory"
            failed_repos=$((failed_repos + 1))
            echo ""
            continue
        }
        
        # Save current branch
        current_branch=$(git symbolic-ref --short HEAD 2>/dev/null)
        if [ -z "$current_branch" ]; then
            echo "  ⚠ Not on a branch (detached HEAD), skipping"
            failed_repos=$((failed_repos + 1))
            cd - > /dev/null || exit
            echo ""
            continue
        fi
        
        # Check if there are uncommitted changes
        stashed=false
        if ! git diff-index --quiet HEAD -- 2>/dev/null || ! git diff --quiet 2>/dev/null; then
            echo "  ⚠ Unstaged changes detected, stashing..."
            if git stash save "Auto-stash by git-pull-rebase-all" > /dev/null 2>&1; then
                stashed=true
            fi
        fi
        
        # Fetch all remotes
        echo "  ↓ Fetching from remotes..."
        if ! git fetch --all --prune > /dev/null 2>&1; then
            echo "  ✗ Failed to fetch from remotes"
            
            # Restore stash if needed
            if [ "$stashed" = true ]; then
                git stash pop > /dev/null 2>&1
            fi
            
            failed_repos=$((failed_repos + 1))
            cd - > /dev/null || exit
            echo ""
            continue
        fi
        
        # Get all local branches with upstream tracking branches
        local_branches=$(git for-each-ref --format='%(refname:short) %(upstream:short)' refs/heads/ | grep -v '^[^ ]* $')
        
        repo_success=true
        updated_count=0
        skipped_count=0
        
        # Update each local branch
        while IFS=' ' read -r branch upstream; do
            if [ -z "$upstream" ]; then
                continue
            fi
            
            echo "  → Updating branch: $branch"
            
            # Checkout the branch
            if ! git checkout "$branch" > /dev/null 2>&1; then
                echo "    ✗ Failed to checkout $branch"
                repo_success=false
                continue
            fi
            
            # Rebase onto upstream
            if git rebase "$upstream" > /dev/null 2>&1; then
                echo "    ✓ Rebased $branch onto $upstream"
                updated_count=$((updated_count + 1))
            else
                echo "    ✗ Failed to rebase $branch"
                # Abort the rebase to leave the repo in a clean state
                git rebase --abort > /dev/null 2>&1
                repo_success=false
            fi
        done <<< "$local_branches"
        
        # Count branches without upstream
        total_branches=$(git for-each-ref --format='%(refname:short)' refs/heads/ | wc -l | tr -d ' ')
        branches_with_upstream=$(echo "$local_branches" | grep -c . || echo 0)
        skipped_count=$((total_branches - branches_with_upstream))
        
        # Return to original branch
        if ! git checkout "$current_branch" > /dev/null 2>&1; then
            echo "  ⚠ Failed to return to original branch: $current_branch"
            repo_success=false
        else
            echo "  ← Returned to branch: $current_branch"
        fi
        
        # Restore stashed changes if any
        if [ "$stashed" = true ]; then
            echo "  ↻ Restoring stashed changes..."
            if git stash pop > /dev/null 2>&1; then
                echo "  ✓ Stashed changes restored"
            else
                echo "  ⚠ Failed to restore stash (may have conflicts)"
                repo_success=false
            fi
        fi
        
        # Print summary for this repo
        if [ "$repo_success" = true ]; then
            echo "  ✓ Repository update complete ($updated_count updated, $skipped_count without upstream)"
            success_repos=$((success_repos + 1))
        else
            echo "  ✗ Repository update had errors"
            failed_repos=$((failed_repos + 1))
        fi
        
        # Return to the original directory
        cd - > /dev/null || exit
        echo ""
    fi
done

# Print summary
echo "================================================"
echo "Summary:"
echo "  Total repositories found: $total_repos"
echo "  Successful: $success_repos"
echo "  Failed: $failed_repos"

# Exit with appropriate code
if [ $failed_repos -gt 0 ]; then
    exit 1
else
    exit 0
fi
